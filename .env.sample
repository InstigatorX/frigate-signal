# Path to the SQLite database file used by the app.
DB_PATH=events.db
# Port the Flask app listens on.
APP_PORT=5001
# Enable Flask/Werkzeug access logs for each HTTP request.
HTTP_ACCESS_LOGS=false
# Hostname or IP address of the MQTT broker.
MQTT_BROKER=192.168.86.252
# Port for the MQTT broker connection.
MQTT_PORT=1883
# MQTT topic the app subscribes to for Frigate review events.
MQTT_TOPIC=frigate/reviews
# Username for authenticating to the MQTT broker.
MQTT_USERNAME=nodered
# Password for the MQTT broker user.
MQTT_PASSWORD=password
# Client ID used when connecting to MQTT.
MQTT_CLIENT_ID=frigate-signal
# Enable TLS for the MQTT connection when set to true.
MQTT_TLS=false
# Public base URL for your Frigate instance or reverse proxy path.
FRIGATE_PUBLIC_BASE=https://ha.xxx.com/nvr
# Prefix Frigate uses for media paths in event payloads.
FRIGATE_MEDIA_PREFIX=/media/frigate
# Optional extra path segment inserted when rewriting Frigate media URLs.
FRIGATE_CLIP_PREFIX=
# Base URL for Frigate VOD/API clip endpoints.
FRIGATE_VOD_BASE=https://ha.xxx.com/nvr/api
# Time window in seconds used to correlate nearby events into the same incident.
INCIDENT_WINDOW_SECONDS=45
# Idle time in seconds before incident AI can run when no more updates arrive.
INCIDENT_LLM_IDLE_SECONDS=15
# Minimum number of events required for an incident to appear in the console.
INCIDENT_MIN_EVENTS=3
# Allow incident-level AI to run before INCIDENT_MIN_EVENTS is reached.
INCIDENT_PROCESS_BELOW_MIN_EVENTS=true
# Grace period before too-small incidents are pruned from the database.
INCIDENT_MIN_EVENTS_PRUNE_SECONDS=45
# Base URL for the LLM API used for incident summaries and visual validation.
LLM_BASE_URL=https://ai.xxx.com/v1
# API key sent to the LLM provider.
LLM_API_KEY=[llm_api_key]
# Model used for incident-level AI synthesis.
LLM_MODEL=openclaw/prime
# Timeout in seconds for LLM API calls.
LLM_TIMEOUT=20
# Timeout in seconds for incident synthesis requests.
INCIDENT_LLM_TIMEOUT=45
# Number of retries for incident synthesis after transient failures.
INCIDENT_LLM_MAX_RETRIES=2
# Path to the camera topology JSON file.
TOPOLOGY_PATH=camera_topology.json
# Maximum camera-graph hops considered connected.
TOPOLOGY_MAX_HOPS=2
# Path to the incident summary prompt file.
PROMPT_PATH=incident_prompt.txt
# Path to the visual validation prompt file.
VISUAL_PROMPT_PATH=visual_validation_prompt.txt
# Enable or disable the background incident worker.
INCIDENT_WORKER_ENABLED=true
# Sleep interval in seconds between worker loops.
INCIDENT_WORKER_INTERVAL=5
# Enable recent incident reconciliation to merge stale split incidents.
INCIDENT_RECONCILIATION_ENABLED=true
# How far back in seconds reconciliation looks for recent incidents.
INCIDENT_RECONCILIATION_RECENT_SECONDS=21600
# Maximum number of events scanned per reconciliation pass.
INCIDENT_RECONCILIATION_MAX_EVENTS=200
# Enable day/night-aware incident prompting.
NIGHT_MODE_ENABLED=true
# Hour when daytime begins for night-mode logic.
DAY_START_HOUR=7
# Hour when nighttime begins for night-mode logic.
NIGHT_START_HOUR=22
# Enable or disable visual validation.
VISUAL_VALIDATION_ENABLED=true
# Matcher used for inter-event visual correlation.
# llm = always use the vision LLM
# hash = always use the local matcher
# hybrid = use the local matcher first, then fall back to the LLM for uncertain cases
VISUAL_MATCHER_MODE=llm
# Local matcher used by hash/hybrid modes.
# hash = lightweight image-hash comparison
# embedding = stronger image-embedding comparison, optionally with YOLO cropping
VISUAL_LOCAL_MATCHER=hash
# Optional detector used to crop the dominant subject before local matching.
# none = compare the full thumbnail
# yolo = detect and crop the main subject before computing similarity
VISUAL_DETECTOR_MODE=none
# YOLO model name or local path used when VISUAL_DETECTOR_MODE=yolo.
VISUAL_DETECTOR_MODEL=yolo11n.pt
# Minimum YOLO detection confidence required before a crop is used.
VISUAL_DETECTOR_CONFIDENCE=0.25
# Hugging Face image embedding model used when VISUAL_LOCAL_MATCHER=embedding.
VISUAL_EMBEDDING_MODEL=openai/clip-vit-base-patch32
# Model used specifically for visual validation.
VISUAL_VALIDATION_MODEL=openclaw/prime
# Minimum number of events required before visual validation runs.
VISUAL_VALIDATION_MIN_EVENTS=3
# Maximum number of images included in one visual validation request.
VISUAL_VALIDATION_MAX_IMAGES=6
# Base confidence threshold for visual matches.
VISUAL_VALIDATION_THRESHOLD=0.45
# Relaxed confidence threshold for same-camera or adjacent-camera hops.
VISUAL_VALIDATION_ADJACENT_THRESHOLD=0.35
# High-confidence local score that auto-accepts a match in hybrid mode.
VISUAL_LOCAL_MATCH_THRESHOLD=0.78
# Low-confidence local score that auto-rejects a match in hybrid mode.
VISUAL_LOCAL_REJECT_THRESHOLD=0.38
# Average-hash size used by the local image matcher.
VISUAL_HASH_SIZE=8
# Suppress noisy native ML backend warnings such as unsupported NNPACK messages.
SUPPRESS_ML_BACKEND_WARNINGS=true
# Enable or disable stitched incident video generation.
VIDEO_GENERATION_ENABLED=true
# Directory where generated incident videos are stored.
VIDEO_OUTPUT_DIR=incident_videos
# Path or command name for the ffmpeg binary.
VIDEO_FFMPEG_BIN=ffmpeg
# Base URL used to fetch source video clips.
VIDEO_SOURCE_BASE=https://ha.xxx.com/nvr/api
# Minimum number of visible events required before generating a video.
VIDEO_MIN_EVENTS=2
# Extra seconds added before and after each source clip.
VIDEO_CLIP_PADDING_SECONDS=1
# Output video width in pixels.
VIDEO_OUTPUT_WIDTH=1280
# Output video height in pixels.
VIDEO_OUTPUT_HEIGHT=720
# Frames per second used for generated videos.
VIDEO_OUTPUT_FPS=15
# H.264 profile used for output encoding.
VIDEO_OUTPUT_PROFILE=main
# H.264 level used for output encoding.
VIDEO_OUTPUT_LEVEL=4.0
# Keyframe interval in seconds for generated videos.
VIDEO_OUTPUT_GOP_SECONDS=2
