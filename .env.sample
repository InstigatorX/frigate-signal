# SQLite database file used to store raw events, incident state, visual results,
# and generated AI summaries. Keep this on persistent storage in production.
DB_PATH=events.db
# TCP port the Flask app listens on inside the container or host.
# Change this only if 5001 is already in use in your environment.
APP_PORT=5001
# Public base URL for this app as seen by browsers and MQTT consumers.
# Used to build full URLs for locally served incident video files.
APP_PUBLIC_BASE=http://localhost:5001
# Set to true to log every HTTP request served by Flask/Werkzeug.
# Useful for debugging API/UI traffic, but usually noisy for normal operation.
HTTP_ACCESS_LOGS=false

# MQTT broker that publishes Frigate review lifecycle messages.
# This should point at the broker Frigate is already sending review events to.
MQTT_BROKER=192.168.86.252
# MQTT broker port. Common values are 1883 for plaintext and 8883 for TLS.
MQTT_PORT=1883
# MQTT topic subscribed to for Frigate review lifecycle events.
# Match this to the topic Frigate publishes review data on.
MQTT_TOPIC=frigate/reviews
# MQTT topic this app publishes compact incident lifecycle updates to.
# Consumers can correlate the initial and enriched messages by `incident_id`.
MQTT_INCIDENT_TOPIC=frigate/signal/incidents
# MQTT username. Leave aligned with your broker credentials.
MQTT_USERNAME=nodered
# MQTT password paired with MQTT_USERNAME.
MQTT_PASSWORD=password
# MQTT client ID used by this app when it connects to the broker.
# Change only if you need to avoid a collision with another client.
MQTT_CLIENT_ID=frigate-signal
# Enable TLS for the MQTT connection.
# Set to true only if your broker expects TLS on the configured port.
MQTT_TLS=false

# Public base URL for Frigate as seen by browsers and by this app when it builds
# review links. This is usually your Home Assistant proxy URL or direct Frigate URL.
FRIGATE_PUBLIC_BASE=https://ha.xxx.com/nvr
# Path prefix Frigate uses in media payloads, typically where snapshots/thumbnails live.
# Only change this if your Frigate deployment exposes media under a different path.
FRIGATE_MEDIA_PREFIX=/media/frigate
# Optional extra path segment added when rewriting media URLs.
# Most installs should leave this blank.
FRIGATE_CLIP_PREFIX=
# Base URL used for Frigate API/VOD clip requests.
# This is typically the Frigate API root and is used for timeline/video generation.
FRIGATE_VOD_BASE=https://ha.xxx.com/nvr/api

# Time window, in seconds, used to group nearby cross-camera events into one incident.
# Increase it if one real-world subject often takes longer to move between cameras.
# Decrease it if unrelated events are being merged together too often.
INCIDENT_WINDOW_SECONDS=45
# Quiet period after all known events are in a terminal state (`end` or `genai`)
# before the incident is considered closed. No visual validation, video generation,
# or incident-level AI runs until this timer expires.
# Increase it if late events regularly arrive after the apparent end of an incident.
# Decrease it if you want downstream processing to begin sooner.
INCIDENT_CLOSE_IDLE_SECONDS=15
# Minimum number of correlated events required before an incident is shown in the UI.
# Raising this reduces noise; lowering it surfaces shorter/smaller incidents.
INCIDENT_MIN_EVENTS=3
# Allow incident-level AI synthesis even when the incident has fewer than
# INCIDENT_MIN_EVENTS events. Most setups should leave this false or use it sparingly.
INCIDENT_PROCESS_BELOW_MIN_EVENTS=true
# How long to keep undersized incidents before pruning them from the database.
# This gives late-arriving events time to merge into them before cleanup happens.
INCIDENT_MIN_EVENTS_PRUNE_SECONDS=45

# Base URL for the OpenAI-compatible LLM API used for incident summaries and,
# depending on visual settings, visual validation.
LLM_BASE_URL=https://ai.xxx.com/v1
# API key or bearer token sent to the configured LLM endpoint.
LLM_API_KEY=[llm_api_key]
# Default language model used for incident-level AI synthesis.
# This should be a model name accepted by your LLM provider.
LLM_MODEL=openclaw/prime
# Default timeout, in seconds, for general LLM API calls.
LLM_TIMEOUT=20
# Timeout, in seconds, specifically for incident-level summary generation.
# This can be longer than LLM_TIMEOUT if incident prompts are heavier.
INCIDENT_LLM_TIMEOUT=45
# Number of times to retry incident synthesis after transient API or parsing failures.
INCIDENT_LLM_MAX_RETRIES=2

# JSON file describing camera adjacency/topology.
# This helps the app understand which camera transitions are physically plausible.
TOPOLOGY_PATH=camera_topology.json
# Maximum number of topology hops considered "nearby" when correlating cameras.
# Lower values make cross-camera grouping stricter.
TOPOLOGY_MAX_HOPS=2

# Prompt file used for incident-level AI summary/title generation.
# Change this if you maintain custom prompting outside the main app code.
PROMPT_PATH=incident_prompt.txt
# Prompt file used for LLM-based visual validation.
VISUAL_PROMPT_PATH=visual_validation_prompt.txt

# Master switch for the background worker loop that processes pending incidents,
# visual validation, and video generation.
INCIDENT_WORKER_ENABLED=true
# Delay, in seconds, between worker passes.
# Lower values reduce latency but increase background churn.
INCIDENT_WORKER_INTERVAL=5

# Enable a repair pass that revisits recent incidents and merges ones that were
# accidentally split apart while events were still arriving.
INCIDENT_RECONCILIATION_ENABLED=true
# Look-back window, in seconds, for the reconciliation pass.
# Larger values are more thorough but cost more work per pass.
INCIDENT_RECONCILIATION_RECENT_SECONDS=21600
# Maximum number of events inspected during one reconciliation pass.
# Increase for busier installs if reconciliation falls behind.
INCIDENT_RECONCILIATION_MAX_EVENTS=200

# Enable different prompt behavior for day vs night scenes.
# This mainly affects incident AI wording and interpretation.
NIGHT_MODE_ENABLED=true
# Local hour when daytime begins, using 24-hour time.
DAY_START_HOUR=7
# Local hour when nighttime begins, using 24-hour time.
NIGHT_START_HOUR=22

# Enable event-to-event visual validation before incidents are summarized.
# When enabled, the app can reject events that do not visually belong to the same subject.
VISUAL_VALIDATION_ENABLED=true
# Strategy used to decide whether consecutive events visually match.
# llm = always use the vision LLM
# hash = always use the local matcher
# hybrid = use the local matcher first, then fall back to the LLM for uncertain cases
VISUAL_MATCHER_MODE=llm
# Local matcher implementation used when VISUAL_MATCHER_MODE is `hash` or `hybrid`.
# hash = lightweight image-hash comparison
# embedding = stronger image-embedding comparison, optionally with YOLO cropping
VISUAL_LOCAL_MATCHER=hash
# Optional object detector used to crop the main subject before local matching.
# This is only relevant for local matching paths, not pure-LLM mode.
# none = compare the full thumbnail
# yolo = detect and crop the main subject before computing similarity
VISUAL_DETECTOR_MODE=none
# YOLO model name or local file path used when VISUAL_DETECTOR_MODE=yolo.
VISUAL_DETECTOR_MODEL=yolo11n.pt
# Minimum detector confidence required before using a cropped subject image.
# Lower values crop more aggressively; higher values fall back to full-frame comparison more often.
VISUAL_DETECTOR_CONFIDENCE=0.25
# Hugging Face image embedding model used for local embedding comparison.
VISUAL_EMBEDDING_MODEL=openai/clip-vit-base-patch32
# Model used specifically for LLM-based visual validation.
# This can be different from LLM_MODEL if you want a dedicated vision-capable model.
VISUAL_VALIDATION_MODEL=openclaw/prime
# Minimum number of incident events required before visual validation is worth running.
VISUAL_VALIDATION_MIN_EVENTS=3
# Maximum number of images sent in one visual validation comparison request.
# Includes both reference images and the candidate image.
VISUAL_VALIDATION_MAX_IMAGES=6
# Default confidence threshold for accepting a visual match.
# Higher values make matching stricter.
VISUAL_VALIDATION_THRESHOLD=0.45
# Lower threshold used for easier transitions such as same-camera or adjacent-camera hops.
VISUAL_VALIDATION_ADJACENT_THRESHOLD=0.35
# In hybrid mode, local scores at or above this threshold are accepted without an LLM call.
VISUAL_LOCAL_MATCH_THRESHOLD=0.78
# In hybrid mode, local scores at or below this threshold are rejected without an LLM call.
VISUAL_LOCAL_REJECT_THRESHOLD=0.38
# Average-hash size used by the local hash matcher.
# Larger values give more detail but may be a bit less forgiving.
VISUAL_HASH_SIZE=8
# Suppress noisy native ML backend warnings produced by Torch/YOLO initialization.
# This hides low-value hardware capability warnings while keeping normal app logs usable.
SUPPRESS_ML_BACKEND_WARNINGS=true

# Enable stitched incident video generation from the clips belonging to an incident.
VIDEO_GENERATION_ENABLED=true
# Directory where generated incident videos are written.
# Make sure this path is writable and persisted if you want videos to survive restarts.
VIDEO_OUTPUT_DIR=incident_videos
# `ffmpeg` executable name or full path used for video creation.
VIDEO_FFMPEG_BIN=ffmpeg
# Base URL used to fetch source clips for stitched incident videos.
VIDEO_SOURCE_BASE=https://ha.xxx.com/nvr/api
# Minimum number of visible events required before generating a stitched video.
VIDEO_MIN_EVENTS=2
# Extra padding added before and after each source clip, in seconds.
# Increase this if clip cuts feel too abrupt.
VIDEO_CLIP_PADDING_SECONDS=1
# Width of generated incident videos, in pixels.
VIDEO_OUTPUT_WIDTH=1280
# Height of generated incident videos, in pixels.
VIDEO_OUTPUT_HEIGHT=720
# Frame rate used for generated videos.
VIDEO_OUTPUT_FPS=15
# H.264 profile used by ffmpeg when encoding output videos.
VIDEO_OUTPUT_PROFILE=main
# H.264 level used by ffmpeg when encoding output videos.
VIDEO_OUTPUT_LEVEL=4.0
# Keyframe interval, in seconds, for generated videos.
VIDEO_OUTPUT_GOP_SECONDS=2
